# Copy this file to .env.local and fill in your own Supabase project values.
# Both values come from Supabase Dashboard -> Project Settings -> API keys.
# The publishable key (sb_publishable_...) is browser-safe; RLS protects your data.
# (Legacy "anon" keys also work here, but Supabase recommends the new format.)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
